# AI Assisted Language Quizzer - Environment Variables Template
# Copy this file to .env and fill in your API keys

# DeepL API Key (required for translation)
# Get yours at: https://www.deepl.com/pro-api
DEEPL_API_KEY=your_deepl_api_key_here

# MiniMax API Key (optional, for LLM curation)
# Get yours at: https://platform.minimaxi.chat/
MINIMAX_API_KEY=your_minimax_api_key_here

# LingQ API Key (optional, for bulk import)
# Get yours at: https://www.lingq.com/en/accounts/apikey/
LINGQ_API_KEY=your_lingq_api_key_here

# AllTalk TTS Server URL (optional, for audio generation)
# Default: http://localhost:8000
# ALLTALK_URL=http://localhost:8000
